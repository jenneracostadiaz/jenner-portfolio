---
import type { GalleryImage } from '../../types/portfolio';

interface Props {
    images: GalleryImage[];
    title: string;
}

const { images, title } = Astro.props;
---

<section id="gallery" class="pt-4">
    <div class="swiper gallery-swiper group relative overflow-hidden rounded-2xl border border-neutral-700/30 bg-neutral-800/20">
        <div class="swiper-wrapper">
            {
                images.map((image, index) => (
                    <div class="swiper-slide">
                        <a
                            href={image.imageUrl}
                            data-pswp-width={image.width}
                            data-pswp-height={image.height}
                            class="gallery-item block cursor-zoom-in"
                        >
                            <figure class="relative">
                                <img
                                    src={image.imageUrl}
                                    alt={image.alt || `${title} imagen ${index + 1}`}
                                    loading="lazy"
                                    class="w-full object-cover"
                                />
                                {image.alt && (
                                    <figcaption class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-4 py-3 text-xs font-light text-neutral-300 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                                        {image.alt}
                                    </figcaption>
                                )}
                            </figure>
                        </a>
                    </div>
                ))
            }
        </div>

        <!-- Navigation buttons -->
        <button
            class="gallery-prev pointer-events-none absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-full border border-neutral-600/40 bg-neutral-900/60 p-2 text-neutral-300 opacity-0 backdrop-blur-sm transition-all duration-300 hover:border-primary-500/50 hover:bg-neutral-900/80 hover:text-primary-400 group-hover:pointer-events-auto group-hover:opacity-100 disabled:opacity-0"
            aria-label="Previous image"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m15 18-6-6 6-6"/>
            </svg>
        </button>
        <button
            class="gallery-next pointer-events-none absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-full border border-neutral-600/40 bg-neutral-900/60 p-2 text-neutral-300 opacity-0 backdrop-blur-sm transition-all duration-300 hover:border-primary-500/50 hover:bg-neutral-900/80 hover:text-primary-400 group-hover:pointer-events-auto group-hover:opacity-100 disabled:opacity-0"
            aria-label="Next image"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
            </svg>
        </button>

        <!-- Counter -->
        {
            images.length > 1 && (
                <div class="pointer-events-none absolute right-3 top-3 z-10 rounded-full border border-neutral-700/40 bg-neutral-900/60 px-3 py-1 font-mono text-xs text-neutral-400 backdrop-blur-sm">
                    <span class="gallery-current">1</span>
                    <span class="mx-1 text-neutral-600">/</span>
                    <span>{images.length}</span>
                </div>
            )
        }
    </div>
</section>

<style is:global>
    @import 'swiper/css';
    @import 'photoswipe/style.css';

    /* PhotoSwipe theme overrides */
    .pswp {
        --pswp-bg: #171717;
        --pswp-icon-color: #d4d4d4;
        --pswp-icon-color-secondary: #737373;
        --pswp-icon-stroke-color: #171717;
        --pswp-icon-stroke-width: 1.2px;
    }

    .pswp__top-bar {
        padding: 0 8px;
    }

    .pswp__button {
        border-radius: 9999px;
        margin: 8px 4px;
        width: 40px;
        height: 40px;
        background-color: rgba(38, 38, 38, 0.7);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(82, 82, 82, 0.3);
        transition: background-color 0.2s, border-color 0.2s;
        display: flex!important;
        align-items: center;
        justify-content: center;
    }

    .pswp__button:hover {
        background-color: rgba(38, 38, 38, 0.95);
        border-color: rgba(83, 106, 255, 0.4);
    }

    .pswp__button--arrow {
        width: 48px;
        height: 48px;
        border-radius: 9999px;
        background-color: rgba(23, 23, 23, 0.65);
        border: 1px solid rgba(82, 82, 82, 0.3);
        backdrop-filter: blur(8px);
    }

    .pswp__button--arrow:hover {
        background-color: rgba(23, 23, 23, 0.9);
        border-color: rgba(83, 106, 255, 0.4);
    }

    .pswp__counter {
        font-family: ui-monospace, monospace;
        font-size: 0.75rem;
        color: #a3a3a3;
        background-color: rgba(23, 23, 23, 0.65);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(82, 82, 82, 0.3);
        border-radius: 9999px;
        padding: 4px 12px;
        margin: 12px 4px;
        height: auto;
        line-height: 1.5;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pswp__icn {
        position: relative;
        top: auto;
        left: auto;
    }

    .pswp__button--arrow--next .pswp__icn,
    .pswp__button--arrow .pswp__icn {
        display: flex;
        justify-content: center;
        align-items: center;
        top: auto;
        margin-top: 0;
    }

    .pswp__button--arrow .pswp__icn {
        left: 8px;
    }

    .pswp__button--arrow--next .pswp__icn {
        left: auto;
        right: 8px;
    }
</style>

<script>
    import Swiper from 'swiper';
    import { Navigation } from 'swiper/modules';
    import PhotoSwipeLightbox from 'photoswipe/lightbox';

    const swiper = new Swiper('.gallery-swiper', {
        modules: [Navigation],
        navigation: {
            nextEl: '.gallery-next',
            prevEl: '.gallery-prev',
            disabledClass: 'disabled',
        },
        slidesPerView: 1,
        spaceBetween: 0,
        on: {
            slideChange(s) {
                const counter = document.querySelector('.gallery-current');
                if (counter) counter.textContent = String(s.realIndex + 1);
            },
        },
    });

    const lightbox = new PhotoSwipeLightbox({
        gallery: '#gallery',
        children: 'a.gallery-item',
        pswpModule: () => import('photoswipe'),
        padding: { top: 56, bottom: 56, left: 80, right: 80 },
    });
    lightbox.init();
</script>
